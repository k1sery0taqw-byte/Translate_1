<!DOCTYPE html>
<html lang="mn">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Manhwa Auto Орчуулагч</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Noto+Sans+Mongolian&family=Noto+Sans+KR&family=IBM+Plex+Mono:wght@400;700&display=swap');

  :root {
    --ink: #0a0a0f;
    --paper: #f5f0e8;
    --accent: #e63946;
    --gold: #f4a261;
    --panel: #12121a;
    --border: #2a2a3a;
    --text-dim: #6b6b8a;
    --white: #ffffff;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--ink);
    color: var(--paper);
    font-family: 'IBM Plex Mono', monospace;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* Halftone background */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: radial-gradient(circle, #ffffff08 1px, transparent 1px);
    background-size: 24px 24px;
    pointer-events: none;
    z-index: 0;
  }

  .wrap {
    position: relative;
    z-index: 1;
    max-width: 480px;
    margin: 0 auto;
    padding: 16px;
  }

  /* Header */
  .header {
    text-align: center;
    padding: 24px 0 20px;
    border-bottom: 2px solid var(--border);
    margin-bottom: 20px;
  }

  .logo {
    font-family: 'Bebas Neue', cursive;
    font-size: 38px;
    letter-spacing: 4px;
    color: var(--white);
    line-height: 1;
    position: relative;
    display: inline-block;
  }

  .logo span {
    color: var(--accent);
  }

  .logo-sub {
    font-size: 10px;
    letter-spacing: 6px;
    color: var(--text-dim);
    text-transform: uppercase;
    margin-top: 4px;
  }

  /* API Key */
  .api-section {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 14px;
    margin-bottom: 16px;
  }

  .api-label {
    font-size: 10px;
    letter-spacing: 3px;
    color: var(--text-dim);
    text-transform: uppercase;
    margin-bottom: 8px;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .api-label::before {
    content: '🔑';
    font-size: 12px;
  }

  .api-input {
    width: 100%;
    background: var(--ink);
    border: 1px solid var(--border);
    border-radius: 4px;
    color: var(--gold);
    font-family: 'IBM Plex Mono', monospace;
    font-size: 13px;
    padding: 10px 12px;
    outline: none;
    transition: border-color 0.2s;
  }

  .api-input:focus { border-color: var(--accent); }
  .api-input::placeholder { color: var(--text-dim); }

  .api-hint {
    font-size: 10px;
    color: var(--text-dim);
    margin-top: 6px;
  }

  .api-hint a { color: var(--gold); }

  /* Upload zone */
  .upload-zone {
    border: 2px dashed var(--border);
    border-radius: 4px;
    padding: 32px 16px;
    text-align: center;
    cursor: pointer;
    transition: all 0.2s;
    background: var(--panel);
    margin-bottom: 16px;
    position: relative;
    overflow: hidden;
  }

  .upload-zone.drag { border-color: var(--accent); background: #1a0a0e; }
  .upload-zone.has-image { padding: 0; border-style: solid; border-color: var(--gold); }

  .upload-icon {
    font-size: 40px;
    display: block;
    margin-bottom: 10px;
    filter: grayscale(0.5);
  }

  .upload-title {
    font-family: 'Bebas Neue', cursive;
    font-size: 20px;
    letter-spacing: 2px;
    color: var(--white);
    margin-bottom: 4px;
  }

  .upload-sub {
    font-size: 11px;
    color: var(--text-dim);
  }

  #file-input { display: none; }

  .preview-img {
    width: 100%;
    display: block;
    border-radius: 2px;
  }

  .preview-overlay {
    position: absolute;
    inset: 0;
    background: #0008;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.2s;
  }

  .upload-zone.has-image:hover .preview-overlay { opacity: 1; }

  .preview-overlay span {
    font-family: 'Bebas Neue', cursive;
    font-size: 18px;
    letter-spacing: 2px;
    color: white;
    background: var(--accent);
    padding: 8px 16px;
    border-radius: 2px;
  }

  /* Translate button */
  .btn-translate {
    width: 100%;
    background: var(--accent);
    color: white;
    border: none;
    border-radius: 4px;
    padding: 16px;
    font-family: 'Bebas Neue', cursive;
    font-size: 22px;
    letter-spacing: 3px;
    cursor: pointer;
    transition: all 0.15s;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
  }

  .btn-translate:hover:not(:disabled) { background: #c1121f; transform: translateY(-1px); }
  .btn-translate:disabled { background: var(--border); color: var(--text-dim); cursor: not-allowed; transform: none; }

  /* Progress */
  .progress-wrap {
    display: none;
    margin-bottom: 16px;
  }

  .progress-wrap.show { display: block; }

  .progress-bar-bg {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 2px;
    height: 6px;
    overflow: hidden;
    margin-bottom: 8px;
  }

  .progress-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--accent), var(--gold));
    border-radius: 2px;
    transition: width 0.4s ease;
    width: 0%;
  }

  .progress-text {
    font-size: 11px;
    color: var(--gold);
    letter-spacing: 2px;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .dot-anim {
    display: inline-flex;
    gap: 3px;
  }

  .dot-anim span {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--gold);
    animation: dotPulse 1.2s ease-in-out infinite;
  }

  .dot-anim span:nth-child(2) { animation-delay: 0.2s; }
  .dot-anim span:nth-child(3) { animation-delay: 0.4s; }

  @keyframes dotPulse {
    0%, 80%, 100% { opacity: 0.2; transform: scale(0.8); }
    40% { opacity: 1; transform: scale(1.2); }
  }

  /* Result */
  .result-wrap {
    display: none;
    margin-bottom: 16px;
  }

  .result-wrap.show { display: block; }

  .result-header {
    font-size: 10px;
    letter-spacing: 3px;
    color: var(--text-dim);
    text-transform: uppercase;
    margin-bottom: 10px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .badge-count {
    background: var(--accent);
    color: white;
    font-size: 10px;
    padding: 2px 8px;
    border-radius: 20px;
    font-family: 'IBM Plex Mono', monospace;
    font-weight: 700;
  }

  #result-canvas {
    width: 100%;
    border: 1px solid var(--gold);
    border-radius: 4px;
    display: block;
    margin-bottom: 12px;
    image-rendering: crisp-edges;
  }

  /* Bubble list */
  .bubble-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 14px;
    max-height: 240px;
    overflow-y: auto;
    padding-right: 4px;
  }

  .bubble-list::-webkit-scrollbar { width: 3px; }
  .bubble-list::-webkit-scrollbar-track { background: var(--panel); }
  .bubble-list::-webkit-scrollbar-thumb { background: var(--border); }

  .bubble-card {
    background: var(--panel);
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: 0 4px 4px 0;
    padding: 10px 12px;
  }

  .bubble-korean {
    font-size: 12px;
    color: var(--text-dim);
    margin-bottom: 4px;
    font-family: 'Noto Sans KR', sans-serif;
  }

  .bubble-arrow {
    color: var(--accent);
    font-size: 10px;
    margin-bottom: 4px;
  }

  .bubble-mongolian {
    font-size: 13px;
    color: var(--gold);
    font-family: 'Noto Sans Mongolian', sans-serif;
    line-height: 1.5;
  }

  /* Download button */
  .btn-download {
    width: 100%;
    background: transparent;
    color: var(--gold);
    border: 2px solid var(--gold);
    border-radius: 4px;
    padding: 14px;
    font-family: 'Bebas Neue', cursive;
    font-size: 20px;
    letter-spacing: 3px;
    cursor: pointer;
    transition: all 0.15s;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-bottom: 10px;
  }

  .btn-download:hover { background: var(--gold); color: var(--ink); }

  .btn-reset {
    width: 100%;
    background: transparent;
    color: var(--text-dim);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 12px;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 12px;
    letter-spacing: 2px;
    cursor: pointer;
    transition: all 0.15s;
    text-transform: uppercase;
  }

  .btn-reset:hover { border-color: var(--text-dim); color: var(--white); }

  /* Error */
  .error-box {
    display: none;
    background: #1a0a0e;
    border: 1px solid var(--accent);
    border-radius: 4px;
    padding: 12px 14px;
    font-size: 12px;
    color: #ff6b7a;
    margin-bottom: 16px;
    line-height: 1.5;
  }

  .error-box.show { display: block; }

  /* Footer */
  .footer {
    text-align: center;
    padding: 16px 0 8px;
    border-top: 1px solid var(--border);
    font-size: 10px;
    color: var(--text-dim);
    letter-spacing: 2px;
  }

  .no-bubbles {
    text-align: center;
    padding: 20px;
    color: var(--text-dim);
    font-size: 12px;
  }
</style>
</head>
<body>
<div class="wrap">

  <div class="header">
    <div class="logo">MANHWA<span>·</span>MN</div>
    <div class="logo-sub">Автомат Орчуулагч · AI Powered</div>
  </div>

  <!-- API Key -->
  <div class="api-section">
    <div class="api-label">Anthropic API Key</div>
    <input
      type="password"
      id="api-key"
      class="api-input"
      placeholder="sk-ant-api03-..."
    />
    <div class="api-hint">
      API key авах: <a href="https://console.anthropic.com" target="_blank">console.anthropic.com</a>
      — нэг удаа оруулсан хадгалагдана
    </div>
  </div>

  <!-- Upload -->
  <div class="upload-zone" id="upload-zone">
    <input type="file" id="file-input" accept="image/*" />
    <span class="upload-icon">📄</span>
    <div class="upload-title">Manhwa зураг оруул</div>
    <div class="upload-sub">JPG / PNG · Дарна уу эсвэл drag хийнэ үү</div>
    <div class="preview-overlay"><span>Өөр зураг</span></div>
  </div>

  <!-- Translate button -->
  <button class="btn-translate" id="btn-translate" disabled>
    <span>⚡</span> ОРЧУУЛАХ
  </button>

  <!-- Progress -->
  <div class="progress-wrap" id="progress-wrap">
    <div class="progress-bar-bg">
      <div class="progress-bar-fill" id="progress-fill"></div>
    </div>
    <div class="progress-text">
      <span id="progress-label">Уншиж байна</span>
      <div class="dot-anim"><span></span><span></span><span></span></div>
    </div>
  </div>

  <!-- Error -->
  <div class="error-box" id="error-box"></div>

  <!-- Result -->
  <div class="result-wrap" id="result-wrap">
    <div class="result-header">
      <span>📋 ОРЧУУЛСАН ТЕКСТ</span>
      <span class="badge-count" id="bubble-count">0 BUBBLE</span>
    </div>
    <canvas id="result-canvas"></canvas>
    <div class="bubble-list" id="bubble-list"></div>
    <button class="btn-download" id="btn-download">⬇ ЗУРАГ ТАТАХ</button>
    <button class="btn-reset" id="btn-reset">↩ Дахин эхлэх</button>
  </div>

  <div class="footer">MANGA.MN · Claude AI · 2025</div>
</div>

<script>
// ── State ──────────────────────────────────────────────────────────────
let uploadedFile = null;
let uploadedDataUrl = null;
let bubbles = [];

const apiKeyInput = document.getElementById('api-key');
const uploadZone = document.getElementById('upload-zone');
const fileInput = document.getElementById('file-input');
const btnTranslate = document.getElementById('btn-translate');
const progressWrap = document.getElementById('progress-wrap');
const progressFill = document.getElementById('progress-fill');
const progressLabel = document.getElementById('progress-label');
const errorBox = document.getElementById('error-box');
const resultWrap = document.getElementById('result-wrap');
const resultCanvas = document.getElementById('result-canvas');
const bubbleList = document.getElementById('bubble-list');
const bubbleCount = document.getElementById('bubble-count');
const btnDownload = document.getElementById('btn-download');
const btnReset = document.getElementById('btn-reset');

// Load saved API key
const savedKey = localStorage.getItem('anthropic_api_key');
if (savedKey) apiKeyInput.value = savedKey;

apiKeyInput.addEventListener('change', () => {
  if (apiKeyInput.value.trim()) {
    localStorage.setItem('anthropic_api_key', apiKeyInput.value.trim());
  }
});

// ── Upload ─────────────────────────────────────────────────────────────
uploadZone.addEventListener('click', () => fileInput.click());

uploadZone.addEventListener('dragover', e => {
  e.preventDefault();
  uploadZone.classList.add('drag');
});
uploadZone.addEventListener('dragleave', () => uploadZone.classList.remove('drag'));
uploadZone.addEventListener('drop', e => {
  e.preventDefault();
  uploadZone.classList.remove('drag');
  const file = e.dataTransfer.files[0];
  if (file && file.type.startsWith('image/')) handleFile(file);
});

fileInput.addEventListener('change', () => {
  if (fileInput.files[0]) handleFile(fileInput.files[0]);
});

function handleFile(file) {
  uploadedFile = file;
  const reader = new FileReader();
  reader.onload = (e) => {
    uploadedDataUrl = e.target.result;
    // Show preview
    uploadZone.classList.add('has-image');
    // Remove old preview img if any
    const old = uploadZone.querySelector('img.preview-img');
    if (old) old.remove();
    const img = document.createElement('img');
    img.className = 'preview-img';
    img.src = uploadedDataUrl;
    uploadZone.insertBefore(img, uploadZone.querySelector('.preview-overlay'));
    // Hide placeholder text
    const icon = uploadZone.querySelector('.upload-icon');
    const title = uploadZone.querySelector('.upload-title');
    const sub = uploadZone.querySelector('.upload-sub');
    if (icon) icon.style.display = 'none';
    if (title) title.style.display = 'none';
    if (sub) sub.style.display = 'none';
    // Enable button
    checkReady();
  };
  reader.readAsDataURL(file);
}

function checkReady() {
  const hasImage = !!uploadedDataUrl;
  const hasKey = apiKeyInput.value.trim().length > 10;
  btnTranslate.disabled = !(hasImage && hasKey);
}

apiKeyInput.addEventListener('input', checkReady);

// ── Translate ──────────────────────────────────────────────────────────
btnTranslate.addEventListener('click', doTranslate);

async function doTranslate() {
  const apiKey = apiKeyInput.value.trim();
  if (!apiKey || !uploadedDataUrl) return;
  localStorage.setItem('anthropic_api_key', apiKey);

  // Reset UI
  hideError();
  resultWrap.classList.remove('show');
  progressWrap.classList.add('show');
  btnTranslate.disabled = true;
  setProgress(10, 'Зураг уншиж байна...');

  try {
    // Extract base64
    const base64 = uploadedDataUrl.split(',')[1];
    const mimeType = uploadedDataUrl.split(';')[0].split(':')[1];

    setProgress(30, 'AI-д илгээж байна...');

    const systemPrompt = `You are a manhwa panel analyzer. Detect ALL Korean text in speech bubbles, thought bubbles, narration boxes, and sound effects.

Return ONLY a valid JSON array with no other text, no markdown, no backticks.

Each object must have:
- "korean": exact Korean text (string)
- "mongolian": Mongolian translation (string, use Mongolian Cyrillic script)
- "x": left edge as percentage of image width (number 0-100)
- "y": top edge as percentage of image height (number 0-100)  
- "w": bubble width as percentage of image width (number 0-100)
- "h": bubble height as percentage of image height (number 0-100)
- "type": "bubble" | "narration" | "sfx"
- "bg": approximate background color inside bubble as hex (e.g. "#ffffff" or "#000000")

If no Korean text exists, return [].
Estimate positions as accurately as possible based on where text appears visually.`;

    const response = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'x-api-key': apiKey,
        'anthropic-version': '2023-06-01',
        'anthropic-dangerous-direct-browser-access': 'true'
      },
      body: JSON.stringify({
        model: 'claude-opus-4-5',
        max_tokens: 2000,
        system: systemPrompt,
        messages: [{
          role: 'user',
          content: [{
            type: 'image',
            source: { type: 'base64', media_type: mimeType, data: base64 }
          }, {
            type: 'text',
            text: 'Analyze this manhwa panel and return the JSON array of all text bubbles with Korean text and Mongolian translations.'
          }]
        }]
      })
    });

    setProgress(70, 'Орчуулж байна...');

    if (!response.ok) {
      const err = await response.json().catch(() => ({}));
      throw new Error(err?.error?.message || `API алдаа: ${response.status}`);
    }

    const data = await response.json();
    const rawText = data.content.map(b => b.text || '').join('');

    // Parse JSON
    let parsed;
    try {
      // Strip markdown fences if any
      const clean = rawText.replace(/```json|```/g, '').trim();
      parsed = JSON.parse(clean);
    } catch (e) {
      throw new Error('AI хариу буруу форматтай байна. Дахин оролдоно уу.');
    }

    if (!Array.isArray(parsed)) parsed = [];
    bubbles = parsed;

    setProgress(90, 'Зураг боловсруулж байна...');
    await renderResult();
    setProgress(100, 'Дууслаа!');

    setTimeout(() => {
      progressWrap.classList.remove('show');
      resultWrap.classList.add('show');
      btnTranslate.disabled = false;
    }, 600);

  } catch (err) {
    progressWrap.classList.remove('show');
    showError(err.message || 'Алдаа гарлаа');
    btnTranslate.disabled = false;
  }
}

// ── Canvas render ──────────────────────────────────────────────────────
async function renderResult() {
  return new Promise((resolve) => {
    const img = new Image();
    img.onload = () => {
      const canvas = resultCanvas;
      canvas.width = img.width;
      canvas.height = img.height;
      const ctx = canvas.getContext('2d');

      // Draw original image
      ctx.drawImage(img, 0, 0);

      // Process each bubble
      bubbles.forEach(b => {
        const x = (b.x / 100) * img.width;
        const y = (b.y / 100) * img.height;
        const w = (b.w / 100) * img.width;
        const h = (b.h / 100) * img.height;

        if (w < 5 || h < 5) return;

        // Fill bubble background (cover Korean text)
        const bg = b.bg || '#ffffff';
        ctx.fillStyle = bg;
        ctx.beginPath();
        const radius = Math.min(w, h) * 0.12;
        ctx.roundRect(x, y, w, h, radius);
        ctx.fill();

        // Stroke
        ctx.strokeStyle = bg === '#ffffff' || bg === '#fff' ? '#cccccc' : '#444444';
        ctx.lineWidth = 1;
        ctx.stroke();

        // Draw Mongolian text
        const isDark = isDarkColor(bg);
        ctx.fillStyle = isDark ? '#ffffff' : '#111111';

        const padding = w * 0.08;
        const maxWidth = w - padding * 2;
        const text = b.mongolian || '';

        // Fit font size
        let fontSize = Math.max(10, Math.min(h * 0.28, w * 0.13, 22));
        ctx.font = `bold ${fontSize}px "Noto Sans Mongolian", "Arial Unicode MS", sans-serif`;

        // Word wrap
        const lines = wrapText(ctx, text, maxWidth);
        const lineH = fontSize * 1.3;
        const totalH = lines.length * lineH;
        let ty = y + (h - totalH) / 2 + fontSize * 0.8;

        // Shrink font if too tall
        if (totalH > h - padding * 2) {
          fontSize = Math.max(8, fontSize * ((h - padding * 2) / totalH));
          ctx.font = `bold ${fontSize}px "Noto Sans Mongolian", "Arial Unicode MS", sans-serif`;
          const lines2 = wrapText(ctx, text, maxWidth);
          const lh2 = fontSize * 1.3;
          ty = y + (h - lines2.length * lh2) / 2 + fontSize * 0.8;
          lines2.forEach((line, i) => {
            ctx.textAlign = 'center';
            ctx.fillText(line, x + w / 2, ty + i * lh2);
          });
        } else {
          lines.forEach((line, i) => {
            ctx.textAlign = 'center';
            ctx.fillText(line, x + w / 2, ty + i * lineH);
          });
        }
      });

      resolve();
    };
    img.src = uploadedDataUrl;
  });
}

function wrapText(ctx, text, maxWidth) {
  if (!text) return [''];
  const words = text.split(' ');
  const lines = [];
  let current = '';
  for (const word of words) {
    const test = current ? current + ' ' + word : word;
    if (ctx.measureText(test).width > maxWidth && current) {
      lines.push(current);
      current = word;
    } else {
      current = test;
    }
  }
  if (current) lines.push(current);
  return lines.length ? lines : [text];
}

function isDarkColor(hex) {
  if (!hex || !hex.startsWith('#')) return false;
  const r = parseInt(hex.slice(1, 3), 16) || 0;
  const g = parseInt(hex.slice(3, 5), 16) || 0;
  const b = parseInt(hex.slice(5, 7), 16) || 0;
  return (r * 299 + g * 587 + b * 114) / 1000 < 128;
}

// ── Bubble list render ─────────────────────────────────────────────────
function renderBubbleList() {
  bubbleList.innerHTML = '';
  bubbleCount.textContent = `${bubbles.length} BUBBLE`;

  if (!bubbles.length) {
    bubbleList.innerHTML = '<div class="no-bubbles">Korean текст олдсонгүй</div>';
    return;
  }

  bubbles.forEach((b, i) => {
    const card = document.createElement('div');
    card.className = 'bubble-card';
    card.innerHTML = `
      <div class="bubble-korean">${escapeHtml(b.korean || '')}</div>
      <div class="bubble-arrow">▼ МОНГОЛ</div>
      <div class="bubble-mongolian">${escapeHtml(b.mongolian || '')}</div>
    `;
    bubbleList.appendChild(card);
  });
}

async function renderResult() {
  return new Promise((resolve) => {
    const img = new Image();
    img.onload = () => {
      const canvas = resultCanvas;
      canvas.width = img.width;
      canvas.height = img.height;
      const ctx = canvas.getContext('2d');
      ctx.drawImage(img, 0, 0);

      bubbles.forEach(b => {
        const x = (b.x / 100) * img.width;
        const y = (b.y / 100) * img.height;
        const w = (b.w / 100) * img.width;
        const h = (b.h / 100) * img.height;
        if (w < 5 || h < 5) return;

        const bg = b.bg || '#ffffff';
        ctx.fillStyle = bg;
        ctx.beginPath();
        const radius = Math.min(w, h) * 0.12;
        if (ctx.roundRect) {
          ctx.roundRect(x, y, w, h, radius);
        } else {
          ctx.rect(x, y, w, h);
        }
        ctx.fill();
        ctx.strokeStyle = isDarkColor(bg) ? '#555' : '#ccc';
        ctx.lineWidth = 1;
        ctx.stroke();

        const isDark = isDarkColor(bg);
        ctx.fillStyle = isDark ? '#ffffff' : '#111111';
        const padding = w * 0.08;
        const maxWidth = w - padding * 2;
        const text = b.mongolian || '';
        let fontSize = Math.max(9, Math.min(h * 0.28, w * 0.13, 24));
        ctx.font = `bold ${fontSize}px Arial, sans-serif`;

        const lines = wrapText(ctx, text, maxWidth);
        const lineH = fontSize * 1.3;
        const totalH = lines.length * lineH;

        if (totalH > h - padding * 2 && lines.length > 1) {
          fontSize = Math.max(8, fontSize * ((h - padding * 2) / totalH) * 0.9);
          ctx.font = `bold ${fontSize}px Arial, sans-serif`;
        }

        const lines2 = wrapText(ctx, text, w - (w * 0.08 * 2));
        const lh2 = fontSize * 1.3;
        const ty = y + (h - lines2.length * lh2) / 2 + fontSize * 0.85;
        ctx.textAlign = 'center';
        lines2.forEach((line, i) => {
          ctx.fillText(line, x + w / 2, ty + i * lh2, w - padding * 2);
        });
      });

      renderBubbleList();
      resolve();
    };
    img.src = uploadedDataUrl;
  });
}

// ── Download ───────────────────────────────────────────────────────────
btnDownload.addEventListener('click', () => {
  const link = document.createElement('a');
  link.download = 'manhwa_translated.png';
  link.href = resultCanvas.toDataURL('image/png');
  link.click();
});

// ── Reset ──────────────────────────────────────────────────────────────
btnReset.addEventListener('click', () => {
  uploadedFile = null;
  uploadedDataUrl = null;
  bubbles = [];
  fileInput.value = '';
  uploadZone.classList.remove('has-image', 'drag');
  const img = uploadZone.querySelector('img.preview-img');
  if (img) img.remove();
  ['upload-icon','upload-title','upload-sub'].forEach(c => {
    const el = uploadZone.querySelector('.' + c);
    if (el) el.style.display = '';
  });
  resultWrap.classList.remove('show');
  hideError();
  btnTranslate.disabled = true;
});

// ── Helpers ────────────────────────────────────────────────────────────
function setProgress(pct, label) {
  progressFill.style.width = pct + '%';
  progressLabel.textContent = label;
}

function showError(msg) {
  errorBox.textContent = '⚠ ' + msg;
  errorBox.classList.add('show');
}

function hideError() {
  errorBox.classList.remove('show');
  errorBox.textContent = '';
}

function escapeHtml(str) {
  return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}
</script>
